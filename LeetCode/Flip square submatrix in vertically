class Solution {
    public int[][] reverseSubmatrix(int[][] matrix, int r, int c, int k) {
        
        for (int i = 0; i < k / 2; i++) {
            for (int j = 0; j < k; j++) {
                int temp = matrix[r + i][c + j];
                matrix[r + i][c + j] = matrix[r + k - 1 - i][c + j];
                matrix[r + k - 1 - i][c + j] = temp;
            }
        }
        
        return matrix; // IMPORTANT
    }
}
